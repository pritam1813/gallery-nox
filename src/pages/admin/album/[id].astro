---
export const prerender = false;
import Layout from "../../../layouts/Layout.astro";
import { env } from "cloudflare:workers";

// 1. Astro SSR: Grab the ID from the URL
const { id } = Astro.params;

if (!id) return Astro.redirect("/admin");

// 2. Fetch the specific album and its photos from D1
const album = await env.DB.prepare("SELECT * FROM Albums WHERE id = ?")
  .bind(id)
  .first();

// If the album doesn't exist, kick them back to the admin dashboard
if (!album) return Astro.redirect("/admin");

const { results: photos } = await env.DB.prepare(
  "SELECT * FROM Photos WHERE albumId = ? ORDER BY createdAt DESC",
)
  .bind(id)
  .all();
---

<Layout title={`Manage: ${album.title}`}>
  <main class="max-w-5xl mx-auto px-4 py-10">
    <header
      class="flex justify-between items-end mb-10 border-b border-zinc-800 pb-6"
    >
      <div>
        <a
          href="/admin"
          class="text-zinc-500 hover:text-zinc-300 text-sm font-medium transition-colors mb-2 inline-block"
        >
          &larr; Back to Dashboard
        </a>
        <h1 class="text-3xl font-extrabold tracking-tight text-white">
          {album.title}
        </h1>
      </div>
      <div class="text-zinc-400 text-sm">
        <span id="photo-count">{photos.length}</span> Photos
      </div>
    </header>

    <section class="mb-12">
      <div
        id="dropzone"
        data-album-id={id}
        class="group relative flex flex-col items-center justify-center w-full h-48 border-2 border-dashed border-zinc-700 rounded-2xl bg-zinc-900/50 hover:bg-zinc-900 hover:border-zinc-500 transition-all cursor-pointer overflow-hidden"
      >
        <div
          id="upload-overlay"
          class="absolute inset-0 bg-black/80 flex-col items-center justify-center z-10 hidden backdrop-blur-sm"
        >
          <div
            class="w-8 h-8 border-4 border-zinc-600 border-t-white rounded-full animate-spin mb-3"
          >
          </div>
          <p
            id="upload-status"
            class="text-sm font-medium text-white tracking-wide"
          >
            Uploading...
          </p>
        </div>

        <svg
          class="w-10 h-10 text-zinc-500 mb-3 group-hover:text-white transition-colors"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"
          ></path>
        </svg>
        <p class="text-sm text-zinc-400 group-hover:text-zinc-200">
          <span class="font-bold text-white">Click to upload</span> or drag and drop
        </p>
        <p class="text-xs text-zinc-500 mt-1">High-res JPEG, PNG, or WebP</p>

        <input
          type="file"
          id="file-upload"
          multiple
          accept="image/*"
          class="hidden"
        />
      </div>
    </section>

    <section>
      <h2 class="text-lg font-bold text-white mb-4">Current Photos</h2>
      <div id="admin-gallery" class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {
          photos.map((photo: any) => (
            <div class="group relative aspect-square rounded-xl overflow-hidden bg-zinc-900 border border-white/5">
              <img
                src={photo.url}
                class="w-full h-full object-cover"
                loading="lazy"
              />

              <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center backdrop-blur-sm">
                <button
                  data-photo-id={photo.id}
                  class="delete-btn bg-red-500/90 hover:bg-red-500 text-white px-4 py-2 rounded-lg text-sm font-bold shadow-lg transform scale-95 group-hover:scale-100 transition-all"
                >
                  Delete
                </button>
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const dropzone = document.getElementById("dropzone");
    const fileInput = document.getElementById(
      "file-upload",
    ) as HTMLInputElement | null;
    const uploadOverlay = document.getElementById("upload-overlay");
    const uploadStatus = document.getElementById("upload-status");

    if (!dropzone || !fileInput) return;

    // Grab the album ID we embedded in the HTML dataset
    const albumId = dropzone.dataset.albumId;

    // --- 1. UI Event Listeners ---
    dropzone.addEventListener("click", () => fileInput.click());

    dropzone.addEventListener("dragover", (e) => {
      e.preventDefault();
      dropzone.classList.add("border-white", "bg-zinc-800");
    });

    dropzone.addEventListener("dragleave", () => {
      dropzone.classList.remove("border-white", "bg-zinc-800");
    });

    dropzone.addEventListener("drop", (e) => {
      e.preventDefault();
      dropzone.classList.remove("border-white", "bg-zinc-800");

      if (e.dataTransfer?.files?.length) {
        handleUploads(e.dataTransfer.files);
      }
    });

    fileInput.addEventListener("change", (e) => {
      const target = e.target as HTMLInputElement;
      if (target.files?.length) {
        handleUploads(target.files);
      }
    });

    // --- 2. Upload Execution Logic ---
    async function handleUploads(files: FileList) {
      if (!albumId || !uploadOverlay || !uploadStatus) return;

      // Show loading UI
      uploadOverlay.classList.remove("hidden");
      uploadOverlay.classList.add("flex");

      let successCount = 0;

      for (let i = 0; i < files.length; i++) {
        const file = files[i];
        uploadStatus.innerText = `Uploading ${i + 1} of ${files.length}...`;

        const formData = new FormData();
        formData.append("photo", file);
        formData.append("albumId", albumId);

        try {
          const res = await fetch("/api/upload", {
            method: "POST",
            body: formData,
          });

          if (res.ok) {
            successCount++;
          }
        } catch (error) {
          console.error("Upload failed for file:", file.name);
        }
      }

      // Refresh the page to show the newly uploaded photos natively via SSR
      uploadStatus.innerText = "Refreshing gallery...";
      window.location.reload();
    }

    // --- 3. Delete Execution Logic ---
    const deleteButtons = document.querySelectorAll(".delete-btn");

    deleteButtons.forEach((button) => {
      button.addEventListener("click", async (e) => {
        // Prevent accidental clicks with a native browser confirm dialog
        const isConfirmed = confirm(
          "Are you sure you want to delete this photo? This cannot be undone.",
        );
        if (!isConfirmed) return;

        const btn = e.currentTarget as HTMLButtonElement;
        const photoId = btn.dataset.photoId;

        // Change button text to show it's working
        const originalText = btn.innerText;
        btn.innerText = "Deleting...";
        btn.disabled = true;

        try {
          const res = await fetch(`/api/photos/${photoId}`, {
            method: "DELETE",
          });

          if (res.ok) {
            // For a snappy UI, instead of reloading the page, we just remove
            // the photo's container from the DOM and update the counter.
            const photoContainer = btn.closest(".group");
            photoContainer?.remove();

            const countEl = document.getElementById("photo-count");
            if (countEl) {
              countEl.innerText = (parseInt(countEl.innerText) - 1).toString();
            }
          } else {
            alert("Failed to delete photo. Please try again.");
            btn.innerText = originalText;
            btn.disabled = false;
          }
        } catch (error) {
          alert("Network error occurred.");
          btn.innerText = originalText;
          btn.disabled = false;
        }
      });
    });
  });
</script>
