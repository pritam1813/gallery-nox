{
	"compatibility_date": "2026-04-10",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "gallery-nox",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "gallery-nox-db",
			"database_id": "76686125-968b-4b2a-89a1-f3b1451a9474",
			"migrations_dir": "migrations"
		}
	]
}