---
// src/pages/album/[id].astro
export const prerender = false; // Explicitly tell Astro this is a server-rendered route

import Layout from "../../layouts/Layout.astro";
import { env } from "cloudflare:workers";

const { id } = Astro.params;

if (!id) return Astro.redirect("/");

// Fetch the specific album and its photos from the real D1 Database
const album = await env.DB.prepare("SELECT * FROM Albums WHERE id = ?")
  .bind(id)
  .first();

if (!album) return Astro.redirect("/");

const { results: photos } = await env.DB.prepare(
  "SELECT * FROM Photos WHERE albumId = ? ORDER BY createdAt DESC",
)
  .bind(id)
  .all();
---

<Layout title={`${album.title} | Gallery`}>
  <main
    id="main-content"
    class="max-w-4xl mx-auto px-4 py-8 transition-all duration-500 ease-out origin-top"
  >
    <a
      href="/"
      class="text-zinc-400 hover:text-white mb-6 inline-block transition-colors"
      >&larr; Back to Galleries</a
    >

    <div class="flex items-end gap-6 mb-10">
      <img
        src={album.coverImage}
        alt={album.title}
        class="w-32 h-32 rounded-2xl object-cover shadow-2xl"
        style={`view-transition-name: album-cover-${album.id}`}
      />
      <div>
        <h1 class="text-4xl font-extrabold tracking-tight">{album.title}</h1>
        <p class="text-zinc-400 mt-1">{photos.length} Photos</p>
      </div>
    </div>

    {
      photos.length === 0 ? (
        <div class="text-center py-20 text-zinc-500">
          No photos in this album yet.
        </div>
      ) : (
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {photos.map((photo: any, index: number) => (
            <button
              class="aspect-4/5 overflow-hidden rounded-xl bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-white active:scale-95 transition-all photo-trigger"
              data-index={index}
            >
              <img
                src={photo.url}
                loading="lazy"
                class="w-full h-full object-cover hover:scale-110 transition-transform duration-500"
              />
            </button>
          ))}
        </div>
      )
    }
  </main>

  <div
    id="fullscreen-viewer"
    class="fixed inset-0 z-50 bg-black/95 backdrop-blur-2xl hidden flex-col opacity-0 scale-[1.02] transition-all duration-500 ease-out"
  >
    <div
      class="absolute top-0 inset-x-0 p-4 flex justify-between items-start z-60 bg-linear-to-b from-black/70 to-transparent"
    >
      <button
        id="close-viewer"
        class="text-white p-2 text-sm font-medium bg-black/50 backdrop-blur-md rounded-full px-4"
      >
        Close
      </button>

      <div class="relative flex flex-col items-end">
        <button
          id="toggle-direction"
          class="text-white p-2 text-sm font-medium bg-black/50 backdrop-blur-md rounded-full px-4 relative z-10 transition-transform active:scale-95"
        >
          Mode: Horizontal
        </button>

        <div
          id="mode-hint"
          class="hidden opacity-0 transition-opacity duration-700 absolute top-full right-0 mt-4 pointer-events-none w-max z-0"
        >
          <div
            class="absolute -top-1.5 right-6 w-3 h-3 bg-zinc-900 rotate-45 z-20"
          >
          </div>
          <div class="relative group">
            <div
              class="absolute -inset-0.5 bg-linear-to-r from-indigo-500 via-purple-500 to-pink-500 rounded-lg blur opacity-75 animate-gradient-glow"
            >
            </div>
            <div
              class="relative bg-zinc-900 px-4 py-2 rounded-lg flex items-center justify-center"
            >
              <span
                class="text-xs font-bold text-transparent bg-clip-text bg-linear-to-r from-pink-400 to-indigo-400 tracking-wide"
              >
                Tap to change direction ✨
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div
      id="swipe-hint"
      class="hidden absolute inset-0 z-70 pointer-events-none items-center justify-center"
    >
      <div
        class="bg-black/60 backdrop-blur-md text-white px-5 py-3 rounded-full flex items-center gap-3 shadow-2xl"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        <span class="font-medium tracking-wide text-sm">Swipe</span>
      </div>
    </div>

    <swiper-container
      id="photo-swiper"
      class="w-full h-dvh"
      direction="horizontal"
      zoom="true"
    >
      {
        photos.map((photo: any) => (
          <swiper-slide class="flex items-center justify-center">
            <div class="swiper-zoom-container">
              <img
                src={photo.url}
                class="max-w-full max-h-full object-contain"
              />
            </div>
          </swiper-slide>
        ))
      }
    </swiper-container>
  </div>
</Layout>

<style is:global>
  @keyframes swipe-nudge {
    0%,
    100% {
      transform: translateX(0);
      opacity: 0;
    }
    20%,
    80% {
      opacity: 1;
    }
    50% {
      transform: translateX(-30px);
      opacity: 1;
    }
  }
  .animate-swipe-nudge {
    animation: swipe-nudge 1.5s ease-in-out 2 forwards;
  }

  @keyframes gradient-shift {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }
  .animate-gradient-glow {
    background-size: 200% 200%;
    animation: gradient-shift 3s ease infinite;
  }
</style>

<script>
  import { register } from "swiper/element/bundle";
  register();

  interface SwiperElement extends HTMLElement {
    swiper: {
      slideTo: (index: number, speed: number) => void;
      changeDirection: (direction: "horizontal" | "vertical") => void;
    };
  }

  document.addEventListener("astro:page-load", () => {
    const mainContent = document.getElementById("main-content");
    const viewer = document.getElementById("fullscreen-viewer");
    const closeBtn = document.getElementById("close-viewer");
    const toggleBtn = document.getElementById("toggle-direction");
    const swiperEl = document.getElementById(
      "photo-swiper",
    ) as SwiperElement | null;
    const triggers = document.querySelectorAll(".photo-trigger");

    const swipeHint = document.getElementById("swipe-hint");
    const modeHint = document.getElementById("mode-hint");

    let modeHintTimeout: ReturnType<typeof setTimeout>;

    if (!viewer || !swiperEl) return;

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const index = parseInt(trigger.getAttribute("data-index") || "0", 10);

        viewer.classList.remove("hidden");
        viewer.classList.add("flex");
        document.body.style.overflow = "hidden";

        swiperEl.swiper.slideTo(index, 0);

        window.requestAnimationFrame(() => {
          viewer.classList.remove("opacity-0", "scale-[1.02]");
          viewer.classList.add("opacity-100", "scale-100");
          mainContent?.classList.add("scale-[0.96]", "opacity-30", "blur-sm");
        });

        if (!localStorage.getItem("hasSeenSwipeHint") && swipeHint) {
          swipeHint.classList.remove("hidden");
          swipeHint.classList.add("flex");
          if (swipeHint.firstElementChild)
            swipeHint.firstElementChild.classList.add("animate-swipe-nudge");
          setTimeout(() => {
            swipeHint.classList.add("hidden");
            swipeHint.classList.remove("flex");
          }, 3000);
          localStorage.setItem("hasSeenSwipeHint", "true");
        }

        if (!localStorage.getItem("hasSeenModeHint") && modeHint) {
          modeHint.classList.remove("hidden");
          modeHintTimeout = setTimeout(() => {
            modeHint.classList.remove("opacity-0");
            modeHint.classList.add("opacity-100");
          }, 3500);
        }
      });
    });

    closeBtn?.addEventListener("click", () => {
      viewer.classList.remove("opacity-100", "scale-100");
      viewer.classList.add("opacity-0", "scale-[1.02]");
      mainContent?.classList.remove("scale-[0.96]", "opacity-30", "blur-sm");

      setTimeout(() => {
        viewer.classList.add("hidden");
        viewer.classList.remove("flex");
        document.body.style.overflow = "";
      }, 500);

      clearTimeout(modeHintTimeout);
    });

    toggleBtn?.addEventListener("click", () => {
      const currentDirection = swiperEl.getAttribute("direction");
      const newDirection =
        currentDirection === "horizontal" ? "vertical" : "horizontal";

      swiperEl.setAttribute("direction", newDirection);
      toggleBtn.innerText = `Mode: ${newDirection.charAt(0).toUpperCase() + newDirection.slice(1)}`;
      swiperEl.swiper.changeDirection(newDirection);

      if (!localStorage.getItem("hasSeenModeHint") && modeHint) {
        modeHint.classList.remove("opacity-100");
        modeHint.classList.add("opacity-0");
        setTimeout(() => modeHint.classList.add("hidden"), 700);
        localStorage.setItem("hasSeenModeHint", "true");
      }
    });
  });
</script>
