---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import { env } from "cloudflare:workers";
import type { Album } from "../data/mock";
import { Image } from "astro:assets";

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=60, stale-while-revalidate=86400",
);

// 1. Check if the user is logged in via Cloudflare Access (Zero Trust)
// Cloudflare Access sets a cookie named 'CF_Authorization' after successful login.
const isAdmin = Astro.cookies.has("CF_Authorization");

// 2. Fetch all albums from the D1 Database
const { results: albums } = await env.DB.prepare(
  "SELECT * FROM Albums ORDER BY createdAt DESC",
).all<Album>();
---

<Layout title="Gallery Nox">
  <main class="max-w-3xl mx-auto px-4 py-8">
    <header class="mb-10 mt-4 flex justify-between items-end">
      <div>
        <h1 class="text-4xl font-extrabold tracking-tight text-white">Galleries</h1>
        <p class="text-zinc-400 mt-2 font-medium text-sm">Select an album to explore.</p>
      </div>

      {
        isAdmin && (
          <a
            href="/admin"
            class="text-zinc-400 hover:text-white text-xs font-bold border border-zinc-800 hover:border-zinc-700 px-4 py-2 rounded-xl transition-all active:scale-95"
          >
            Dashboard &rarr;
          </a>
        )
      }
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {
        albums.map((album) => (
          <a
            href={`/album/${album.id}`}
            class="group block relative aspect-square overflow-hidden rounded-3xl bg-zinc-900 border border-white/5 active:scale-95 transition-transform"
          >
            <Image
              src={album.coverImage}
              alt={album.title}
              width={800}
              height={800}
              loading="lazy"
              class="object-cover w-full h-full transition-transform duration-700 ease-out group-hover:scale-105"
              style={`view-transition-name: album-cover-${album.id}`}
            />

            <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/30 to-transparent flex flex-col justify-end p-6">
              <h2 class="text-2xl font-bold text-white tracking-wide">
                {album.title}
              </h2>
              <p class="text-sm text-zinc-300 mt-1 uppercase tracking-widest">
                {album.photoCount} Photos
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
