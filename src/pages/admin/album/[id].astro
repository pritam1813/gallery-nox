---
export const prerender = false;
import Layout from "../../../layouts/Layout.astro";
import { env } from "cloudflare:workers";
import { Image } from "astro:assets";

// 1. Astro SSR: Grab the ID from the URL
const { id } = Astro.params;

if (!id) return Astro.redirect("/admin");

// 2. Fetch the specific album and its photos from D1
const album = (await env.DB.prepare("SELECT * FROM Albums WHERE id = ?")
  .bind(id)
  .first()) as any;

// If the album doesn't exist, kick them back to the admin dashboard
if (!album) return Astro.redirect("/admin");

const { results: photos } = await env.DB.prepare(
  "SELECT * FROM Photos WHERE albumId = ? ORDER BY createdAt DESC",
)
  .bind(id)
  .all();
---

<Layout title={`Manage: ${album.title}`}>
  <main class="max-w-5xl mx-auto px-4 py-10">
    <header
      class="flex justify-between items-start mb-10 border-b border-zinc-800 pb-6"
    >
      <div class="flex gap-6">
        <div class="relative group w-32 h-32 rounded-2xl overflow-hidden bg-zinc-900 border border-white/10 shrink-0">
          <img
            id="current-cover"
            src={album.coverImage}
            alt="Album Cover"
            class="w-full h-full object-cover"
          />
          <button
            id="change-cover-btn"
            class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center text-white text-[10px] font-bold gap-1"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            CHANGE COVER
          </button>
          <input type="file" id="cover-upload" accept="image/*" class="hidden" />
        </div>
        <div>
          <a
            href="/admin"
            class="text-zinc-500 hover:text-zinc-300 text-sm font-medium transition-colors mb-2 inline-block"
          >
            &larr; Back to Dashboard
          </a>
          <h1 class="text-3xl font-extrabold tracking-tight text-white mb-2">
            {album.title}
          </h1>
          <div class="flex items-center gap-4">
            <div class="text-zinc-400 text-sm">
              <span id="photo-count">{photos.length}</span> Photos
            </div>
            <button
              id="open-delete-album-btn"
              class="text-red-500 hover:text-red-400 text-xs font-bold transition-colors"
            >
              Delete Album
            </button>
          </div>
        </div>
      </div>
    </header>

    <section class="mb-12">
      <div
        id="dropzone"
        data-album-id={id}
        class="group relative flex flex-col items-center justify-center w-full h-48 border-2 border-dashed border-zinc-700 rounded-2xl bg-zinc-900/50 hover:bg-zinc-900 hover:border-zinc-500 transition-all cursor-pointer overflow-hidden"
      >
        <div
          id="upload-overlay"
          class="absolute inset-0 bg-black/80 flex-col items-center justify-center z-10 hidden backdrop-blur-sm"
        >
          <div
            class="w-8 h-8 border-4 border-zinc-600 border-t-white rounded-full animate-spin mb-3"
          >
          </div>
          <p
            id="upload-status"
            class="text-sm font-medium text-white tracking-wide"
          >
            Uploading...
          </p>
        </div>

        <svg
          class="w-10 h-10 text-zinc-500 mb-3 group-hover:text-white transition-colors"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"
          ></path>
        </svg>
        <p class="text-sm text-zinc-400 group-hover:text-zinc-200">
          <span class="font-bold text-white">Click to upload photos</span> or drag and drop
        </p>
        <p class="text-xs text-zinc-500 mt-1">High-res JPEG, PNG, or WebP</p>

        <input
          type="file"
          id="file-upload"
          multiple
          accept="image/*"
          class="hidden"
        />
      </div>
    </section>

    <section>
      <h2 class="text-lg font-bold text-white mb-4">Current Photos</h2>
      <div id="admin-gallery" class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {
          photos.map((photo: any) => (
            <div class="group relative aspect-square rounded-xl overflow-hidden bg-zinc-900 border border-white/5">
              <img
                src={photo.url}
                class="w-full h-full object-cover"
                loading="lazy"
              />

              <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center gap-2 backdrop-blur-sm">
                <button
                  data-photo-url={photo.url}
                  class="set-cover-btn bg-white text-black hover:bg-zinc-200 px-3 py-1.5 rounded-lg text-xs font-bold shadow-lg transform scale-95 group-hover:scale-100 transition-all"
                >
                  Set as Cover
                </button>
                <button
                  data-photo-id={photo.id}
                  class="open-delete-photo-btn bg-red-500/90 hover:bg-red-500 text-white px-3 py-1.5 rounded-lg text-xs font-bold shadow-lg transform scale-95 group-hover:scale-100 transition-all"
                >
                  Delete Photo
                </button>
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>

  <div
    id="confirm-modal"
    class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden items-center justify-center opacity-0 transition-opacity duration-300"
  >
    <div
      class="bg-zinc-950 border border-zinc-800 p-8 rounded-3xl w-full max-w-md shadow-2xl transform scale-95 transition-transform duration-300"
      id="modal-content"
    >
      <h2 id="modal-title" class="text-2xl font-bold text-white mb-2">Confirm Action</h2>
      <p id="modal-desc" class="text-sm text-zinc-400 mb-6">This action cannot be undone.</p>

      <div class="flex justify-end gap-3 mt-4">
        <button
          type="button"
          id="close-modal-btn"
          class="px-5 py-2.5 rounded-xl text-sm font-bold text-zinc-300 hover:text-white hover:bg-zinc-800 transition-colors"
        >
          Cancel
        </button>
        <button
          type="button"
          id="confirm-action-btn"
          class="bg-red-500 text-white hover:bg-red-600 px-5 py-2.5 rounded-xl text-sm font-bold transition-colors"
        >
          Confirm
        </button>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const dropzone = document.getElementById("dropzone");
    const fileInput = document.getElementById("file-upload") as HTMLInputElement;
    const uploadOverlay = document.getElementById("upload-overlay");
    const uploadStatus = document.getElementById("upload-status");
    
    const changeCoverBtn = document.getElementById("change-cover-btn");
    const coverUploadInput = document.getElementById("cover-upload") as HTMLInputElement;
    const currentCoverImg = document.getElementById("current-cover") as HTMLImageElement;

    const modal = document.getElementById("confirm-modal");
    const modalContent = document.getElementById("modal-content");
    const modalTitle = document.getElementById("modal-title");
    const modalDesc = document.getElementById("modal-desc");
    const closeBtn = document.getElementById("close-modal-btn");
    const confirmBtn = document.getElementById("confirm-action-btn") as HTMLButtonElement;

    if (!dropzone || !fileInput || !modal || !confirmBtn) return;

    const albumId = dropzone.dataset.albumId;

    // --- Cover Image Logic ---
    changeCoverBtn?.addEventListener("click", () => coverUploadInput.click());

    coverUploadInput?.addEventListener("change", async (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file || !albumId) return;

      const formData = new FormData();
      formData.append("photo", file);
      formData.append("albumId", albumId);
      formData.append("isCover", "true");

      try {
        const res = await fetch("/api/upload", {
          method: "POST",
          body: formData,
        });

        if (res.ok) {
          const data = await res.json();
          if (currentCoverImg) currentCoverImg.src = data.url;
        } else {
          alert("Failed to upload cover image.");
        }
      } catch (error) {
        alert("Network error.");
      }
    });

    const setCoverBtns = document.querySelectorAll(".set-cover-btn");
    setCoverBtns.forEach(btn => {
      btn.addEventListener("click", async (e) => {
        const url = (e.currentTarget as HTMLButtonElement).dataset.photoUrl;
        if (!url || !albumId) return;

        try {
          const res = await fetch(`/api/albums/${albumId}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ coverImage: url }),
          });

          if (res.ok) {
            if (currentCoverImg) currentCoverImg.src = url;
          } else {
            alert("Failed to set album cover.");
          }
        } catch (error) {
          alert("Network error.");
        }
      });
    });

    // --- Modal Logic ---
    let actionToPerform: (() => Promise<void>) | null = null;

    const openModal = (title: string, desc: string, action: () => Promise<void>, confirmText = "Delete", confirmClass = "bg-red-500 hover:bg-red-600") => {
      if (modalTitle) modalTitle.innerText = title;
      if (modalDesc) modalDesc.innerText = desc;
      actionToPerform = action;
      
      confirmBtn.innerText = confirmText;
      confirmBtn.className = `${confirmClass} px-5 py-2.5 rounded-xl text-sm font-bold transition-colors`;
      
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      requestAnimationFrame(() => {
        modal.classList.remove("opacity-0");
        modalContent?.classList.remove("scale-95");
        modalContent?.classList.add("scale-100");
      });
    };

    const closeModal = () => {
      modal.classList.add("opacity-0");
      modalContent?.classList.remove("scale-100");
      modalContent?.classList.add("scale-95");
      setTimeout(() => {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
        actionToPerform = null;
        confirmBtn.disabled = false;
      }, 300);
    };

    closeBtn?.addEventListener("click", closeModal);
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });

    confirmBtn.addEventListener("click", async () => {
      if (actionToPerform) {
        confirmBtn.disabled = true;
        const originalText = confirmBtn.innerText;
        confirmBtn.innerText = "Processing...";
        await actionToPerform();
        closeModal();
      }
    });

    // --- Upload Execution Logic ---
    async function handleUploads(files: FileList) {
      if (!albumId || !uploadOverlay || !uploadStatus) return;

      uploadOverlay.classList.remove("hidden");
      uploadOverlay.classList.add("flex");

      for (let i = 0; i < files.length; i++) {
        const file = files[i];
        uploadStatus.innerText = `Uploading ${i + 1} of ${files.length}...`;

        const formData = new FormData();
        formData.append("photo", file);
        formData.append("albumId", albumId);

        try {
          await fetch("/api/upload", {
            method: "POST",
            body: formData,
          });
        } catch (error) {
          console.error("Upload failed for file:", file.name);
        }
      }

      window.location.reload();
    }

    dropzone.addEventListener("click", () => fileInput.click());
    dropzone.addEventListener("dragover", (e) => { e.preventDefault(); dropzone.classList.add("border-white", "bg-zinc-800"); });
    dropzone.addEventListener("dragleave", () => { dropzone.classList.remove("border-white", "bg-zinc-800"); });
    dropzone.addEventListener("drop", (e) => {
      e.preventDefault();
      dropzone.classList.remove("border-white", "bg-zinc-800");
      if (e.dataTransfer?.files?.length) handleUploads(e.dataTransfer.files);
    });
    fileInput.addEventListener("change", (e) => {
      const target = e.target as HTMLInputElement;
      if (target.files?.length) handleUploads(target.files);
    });

    // --- Delete Execution Logic ---
    const deletePhotoBtns = document.querySelectorAll(".open-delete-photo-btn");
    deletePhotoBtns.forEach((button) => {
      button.addEventListener("click", (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const photoId = btn.dataset.photoId;
        openModal(
          "Delete Photo",
          "Are you sure you want to delete this photo? This cannot be undone.",
          async () => {
            try {
              const res = await fetch(`/api/photos/${photoId}`, { method: "DELETE" });
              if (res.ok) {
                btn.closest(".group")?.remove();
                const countEl = document.getElementById("photo-count");
                if (countEl) countEl.innerText = (parseInt(countEl.innerText) - 1).toString();
                // We might want to refresh if the cover was deleted, 
                // but the API already handles reverting to default in DB.
                // A full reload or updating currentCoverImg would be safer.
                window.location.reload();
              } else { alert("Failed to delete photo."); }
            } catch (error) { alert("Network error occurred."); }
          }
        );
      });
    });

    const deleteAlbumBtn = document.getElementById("open-delete-album-btn");
    deleteAlbumBtn?.addEventListener("click", () => {
      openModal(
        "Delete Album",
        "Are you sure you want to delete this ENTIRE album and ALL its photos? This action is permanent and cannot be undone.",
        async () => {
          try {
            const res = await fetch(`/api/albums/${albumId}`, { method: "DELETE" });
            if (res.ok) { window.location.href = "/admin"; } 
            else { alert("Failed to delete album."); }
          } catch (error) { alert("Network error occurred."); }
        }
      );
    });
  });
</script>
